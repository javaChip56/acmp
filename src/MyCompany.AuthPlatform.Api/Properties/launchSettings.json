{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:15597",
      "sslPort": 44391
    }
  },
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:5280",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "https://localhost:7140;http://localhost:5280",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "https-remote-minikms": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "https://localhost:7140;http://localhost:5280",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "MiniKms__Provider": "RemoteMiniKms",
        "MiniKms__Remote__BaseUrl": "https://localhost:7190",
        "MiniKms__Remote__TimeoutSeconds": "15",
        "MiniKms__Remote__InternalJwt__KeySource": "MiniKmsState",
        "MiniKms__Remote__InternalJwt__Issuer": "acmp-internal-services",
        "MiniKms__Remote__InternalJwt__Audience": "mini-kms-internal",
        "MiniKms__Remote__InternalJwt__ActiveKeyVersion": "svcjwt-v1",
        "MiniKms__Remote__InternalJwt__Subject": "acmp-api",
        "MiniKms__Remote__InternalJwt__TokenLifetimeMinutes": "5",
        "MiniKms__Remote__InternalJwt__ManagedState__Provider": "File",
        "MiniKms__Remote__InternalJwt__ManagedState__StateFilePath": "..\\MyCompany.Security.MiniKms\\App_Data\\minikms-internal-jwt-state.development.json"
      }
    },
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  }
}
