@MyCompany.AuthPlatform.Api_HostAddress = http://localhost:5280
@adminUserId = 00000000-0000-0000-0000-000000000000

GET {{MyCompany.AuthPlatform.Api_HostAddress}}/health
Accept: application/json

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/auth/token
Content-Type: application/json

{
  "username": "administrator.demo",
  "password": "AdministratorPass!123"
}

###

GET {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users
Accept: application/json
Authorization: Bearer <paste-token-here>

###

GET {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users/{{adminUserId}}
Accept: application/json
Authorization: Bearer <paste-token-here>

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "username": "auditor.demo",
  "displayName": "Demo Auditor",
  "password": "AuditorPass!123",
  "roles": [
    "AccessViewer"
  ]
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users/{{adminUserId}}/disable
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "reason": "Demo disable request"
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users/{{adminUserId}}/reset-password
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "newPassword": "UpdatedPass!123",
  "reason": "Demo password reset"
}

###

PUT {{MyCompany.AuthPlatform.Api_HostAddress}}/api/admin/users/{{adminUserId}}/roles
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "roles": [
    "AccessViewer",
    "AccessOperator"
  ],
  "reason": "Demo role update"
}

###

GET {{MyCompany.AuthPlatform.Api_HostAddress}}/api/system/info
Accept: application/json

###

GET {{MyCompany.AuthPlatform.Api_HostAddress}}/api/clients
Accept: application/json
Authorization: Bearer <paste-token-here>

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/clients
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "clientCode": "inventory-api",
  "clientName": "Inventory API",
  "owner": "Supply Chain Team",
  "environment": "Uat",
  "description": "Demo client created from the HTTP scratch file.",
  "metadataJson": "{\"contactEmail\":\"supply-chain@example.internal\"}"
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/clients/1f4a8ec5-31f6-4df8-8b7d-6c22f4f9d0a1/credentials/hmac
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "expiresAt": "2027-04-01T00:00:00Z",
  "scopes": [
    "orders.read"
  ],
  "notes": "Demo-issued credential"
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/credentials/bd0dd9fc-90d2-4dc8-a99e-5f5d65d8b041/rotate
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "expiresAt": "2027-05-01T00:00:00Z",
  "gracePeriodEndsAt": "2026-04-20T00:00:00Z",
  "notes": "Rotated in demo mode",
  "reason": "Demonstrating extended grace period approval."
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/credentials/1f8e89ef-80cf-4e56-bf58-0f8684ea7d0e/revoke
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "reason": "Demo revocation request"
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/credentials/bd0dd9fc-90d2-4dc8-a99e-5f5d65d8b041/issue-encrypted-package
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "bindingType": "X509StoreThumbprint",
  "certificateThumbprint": "<paste-thumbprint-here>",
  "storeLocation": "CurrentUser",
  "storeName": "My",
  "certificatePath": null,
  "privateKeyPath": null,
  "certificatePem": null,
  "reason": "Issue service-side validation package"
}

###

POST {{MyCompany.AuthPlatform.Api_HostAddress}}/api/credentials/bd0dd9fc-90d2-4dc8-a99e-5f5d65d8b041/issue-client-package
Content-Type: application/json
Authorization: Bearer <paste-token-here>

{
  "bindingType": "X509StoreThumbprint",
  "certificateThumbprint": "<paste-thumbprint-here>",
  "storeLocation": "CurrentUser",
  "storeName": "My",
  "certificatePath": null,
  "privateKeyPath": null,
  "certificatePem": null,
  "reason": "Issue client-side signing package"
}

